  91:libDaisy/src/daisy_core.h ****     return (uint8_t)((x * F2U8_SCALE) + F2U8_SCALE);
  92:libDaisy/src/daisy_core.h **** }
  93:libDaisy/src/daisy_core.h **** 
  94:libDaisy/src/daisy_core.h **** 
