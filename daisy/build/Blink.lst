  62:libDaisy/src/per/dac.h ****     /** Sets whether the DAC output is buffered for higher drive ability. */
  63:libDaisy/src/per/dac.h ****     enum class BufferState
  64:libDaisy/src/per/dac.h ****     {
  65:libDaisy/src/per/dac.h ****         ENABLED,
